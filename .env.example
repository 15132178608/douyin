# ============================================================
# 抖音收藏回忆工具 配置模板
# 拷贝为 .env 后填实际值。.env 不要提交到 git。
# ============================================================

# ---- 数据库 ----
DB_PATH=data/recall.db

# ---- Playwright 浏览器登录态目录 ----
# 第一次启动会要求扫码登录，之后复用这个目录里的 cookie
PLAYWRIGHT_PROFILE_PATH=data/playwright_profile

# ---- 头像缓存 ----
# Web UI 会缓存作者头像；默认写到项目 data/ 下，不应提交到 git
AVATAR_CACHE_DIR=data/avatar_cache

# ---- Web 服务 ----
# 个人本地工具默认只监听本机；不要改成 0.0.0.0，除非你清楚公网暴露风险
WEB_HOST=127.0.0.1
WEB_PORT=8000

# ---- 访问控制 ----
# 个人本地使用保持 false；如果你自行对外开放，必须改成 true
WEB_AUTH_REQUIRED=false
# SESSION 有效天数（默认 30 天）
SESSION_DAYS=30

# ---- 邮件（M2 用） ----
# Gmail 示例（需要先在 Google 账号里开 App Password，不是登录密码）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password_here
MAIL_FROM=you@example.com
MAIL_TO=you@example.com

# ---- 推送策略 ----
# 每周邮件里推荐多少条
DIGEST_COUNT=6
# 一条收藏距离上次召回多少天内就不再推送
RECALL_COOLDOWN_DAYS=30
# 收藏距离首次抓取多少天后才进入推荐池（避免新收的立刻被"忘记")
RECALL_WARMUP_DAYS=14

# ---- 抓取节流 ----
# 滚动一次后的最小/最大停顿秒数（模拟人类）
CRAWL_SLEEP_MIN=1.5
CRAWL_SLEEP_MAX=3.0

# ---- 日志 ----
LOG_LEVEL=INFO
